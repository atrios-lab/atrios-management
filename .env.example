# Postgres — sem servidor local? suba um:
#   docker run -d --name atrios-pg -p 5432:5432 -e POSTGRES_PASSWORD=postgres -e POSTGRES_DB=atrios postgres:17-alpine
DATABASE_URL=postgres://postgres:postgres@localhost:5432/atrios

# openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# OAuth apps (callback: $BETTER_AUTH_URL/api/auth/callback/<provider>)
# Sem credenciais, o provedor fica desabilitado — email+senha continua funcionando.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
